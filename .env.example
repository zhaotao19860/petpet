POSTGRES_USER=petpet
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=petpet
DATABASE_URL=postgresql://petpet:change-this-password@postgres:5432/petpet
SESSION_SECRET=change-this-long-random-secret
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost
WEB_PORT=80
AI_PROVIDER=oneapi
AI_BASE_URL=https://oneapi-comate.baidu-int.com
ONEAPI_TOKEN=change-this-token
AI_FAST_MODEL=GLM-5-Turbo
AI_SMART_MODEL=GPT-5.4-Mini
AI_MODEL_STRATEGY=speed-first
AI_TIMEOUT_MS=5000
AI_LONG_STORY_TIMEOUT_MS=60000
AI_LONG_STORY_MAX_TOKENS=12000
TTS_PROVIDER=edge
TTS_EDGE_OUTPUT_FORMAT=audio-24khz-96kbitrate-mono-mp3
STT_PROVIDER=cloudflare
CLOUDFLARE_ACCOUNT_ID=change-this-cloudflare-account-id
CLOUDFLARE_API_TOKEN=change-this-cloudflare-api-token
CLOUDFLARE_BASE_URL=https://api.cloudflare.com/client/v4
CLOUDFLARE_STT_MODEL=@cf/openai/whisper
AI_STT_MODEL=whisper-1
AI_STT_TIMEOUT_MS=12000
