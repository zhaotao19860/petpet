{
  "name": "petpet",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build && node scripts/prune-original-animal-images.mjs dist",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -b",
    "sounds:build": "node scripts/build-real-sound-assets.mjs",
    "sounds:test": "node --test scripts/sound-pipeline.test.mjs",
    "images:build": "node scripts/build-image-assets.mjs",
    "starbuddy:test": "node --test scripts/star-buddy-play.test.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "ffmpeg-static": "^5.3.0",
    "sharp": "^0.34.5"
  }
}
